# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/shiporshame

# GitHub OAuth App credentials (https://github.com/settings/developers)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Resend transactional email API key (https://resend.com)
RESEND_API_KEY=
# Verified "from" address for nudge emails
RESEND_FROM_EMAIL=ShipOrShame <nudges@shiporsham.app>

# 32+ random bytes (hex) used to sign sessions AND derive the AES-256-GCM token key.
# Generate with: openssl rand -hex 32
SESSION_SECRET=

# Public base URL of the app (no trailing slash)
PUBLIC_APP_URL=http://localhost:5173

# Secret bearer token required to call POST /api/cron/nudges
# Generate with: openssl rand -hex 32
CRON_SECRET=
